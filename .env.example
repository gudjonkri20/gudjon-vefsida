# Anthropic API key for the "Ask Guðjón AI" Netlify Function.
# This must be Guðjón's PERSONAL key from console.anthropic.com — never a company key.
# Set in production via: netlify env:set ANTHROPIC_API_KEY <key>
# When unset, the chat widget shows an "AI is offline — email me directly" fallback.
ANTHROPIC_API_KEY=
